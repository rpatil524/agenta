{
  "name": "@agenta/api-client",
  "version": "0.0.0-dev",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "browser": {
    "fs": false,
    "stream": false,
    "stream/web": false,
    "buffer": false
  },
  "files": [
    "src"
  ],
  "scripts": {
    "generate": "bash ../../../clients/scripts/generate.sh --language typescript",
    "build": "pnpm run types:check",
    "types:check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.20",
    "typescript": "^5.9.3"
  }
}
